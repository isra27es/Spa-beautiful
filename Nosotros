<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Beauty Spa - Galería</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Arial', sans-serif;
    }

    body {
      background-color: #c48957;
      color: white;
    }

    .hero {
      background-image: url('/fondo.jpg'); /* 🔁 Cambia aquí tu imagen */
      background-size: cover;
      background-position: center;
      height: 100vh;
      padding: 60px 30px 30px 30px;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      position: relative;
    }

    .hero h1 {
      font-size: 3rem;
      color: #d9a96a;
    }

    .slogan {
      margin-top: 10px;
      font-style: italic;
      font-weight: bold;
      font-size: 1.1rem;
    }

    .top-right {
      position: absolute;
      top: 20px;
      right: 20px;
      display: flex;
      gap: 20px;
      font-size: 0.9rem;
    }

    .top-right a {
      color: white;
      text-decoration: none;
    }

    .menu {
      margin-top: 20px;
      display: flex;
      gap: 20px;
      font-size: 1rem;
    }

    .menu a {
      text-decoration: none;
      color: white;
    }

    .gallery-title {
      text-align: center;
      padding: 30px 20px 10px;
      font-size: 1.3rem;
      background-color: #c48957;
      font-weight: bold;
      letter-spacing: 1px;
    }

    .section-title {
      background-color: #1a2d2b;
      padding: 15px;
      text-align: center;
      font-size: 1.5rem;
      color: #b6c9d0;
      font-weight: bold;
      text-transform: uppercase;
    }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 20px;
      padding: 30px;
    }

    .service-item {
      background-color: #fff;
      border-radius: 5px;
      overflow: hidden;
      color: black;
      text-align: center;
      position: relative;
    }

    .service-item img {
      width: 100%;
      height: 140px;
      object-fit: cover;
    }

    .service-title {
      padding: 10px;
      font-weight: bold;
      font-size: 0.95rem;
      background-color: #f3e6d8;
    }

    /* ===== Carrusel styles dentro de un service-item ===== */
    .carousel-container {
      width: 100%;
      height: 200px;
      position: relative;
      overflow: hidden;
      border-radius: 5px;
      background-color: white;
    }

    .carousel-slide {
      width: 100%;
      height: 100%;
      display: flex;
      transition: transform 0.5s ease-in-out;
    }

    .carousel-image {
      min-width: 100%;
      height: 100%;
      position: relative;
    }

    .carousel-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .carousel-title {
      position: absolute;
      bottom: 10px;
      left: 0;
      right: 0;
      text-align: center;
      color: white;
      font-size: 1rem;
      font-weight: bold;
      letter-spacing: 1px;
      text-shadow: 1px 1px 3px rgba(0,0,0,0.7);
    }

    .carousel-button {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      background-color: rgba(0, 0, 0, 0.5);
      border: 2px solid white;
      color: white;
      width: 30px;
      height: 30px;
      border-radius: 50%;
      font-size: 1.2rem;
      cursor: pointer;
      z-index: 2;
    }

    .carousel-button:hover {
      background-color: rgba(255, 255, 255, 0.3);
    }

    .prev {
      left: 5px;
    }

    .next {
      right: 5px;
    }

    @media (max-width: 600px) {
      .hero h1 {
        font-size: 2rem;
      }
      .section-title {
        font-size: 1.2rem;
      }
    }
  </style>
</head>
<body>

  <!-- Portada -->
  <div class="hero">
    <div class="top-right">
      <a href="#">LLÁMANOS 📞</a>
      <a href="#">Login</a>
    </div>

    <h1>BEAUTY SPA</h1>
    <p class="slogan">ÉLÉGANCE ET BIEN-ÊTRE,<br>À VOTRE PORTÉE.</p>

    <div class="menu">
      <a href="#">Vidéos</a>
      <a href="#">Produits</a>
      <a href="#">Galería</a>
      <a href="#">Nousotros</a>
    </div>
  </div>

  <!-- Títulos -->
  <div class="gallery-title">GALERÍA DE FOTOGRAFÍAS</div>
  <div class="section-title">IMÁGENES DE<br>NUESTROS SERVICIOS</div>

  <!-- Galería con carrusel incluido -->
  <div class="services-grid">
    <!-- Carrusel -->
    <div class="service-item">
      <div class="carousel-container">
        <div class="carousel-slide" id="carouselSlide">
          <div class="carousel-image">
            <img src="/msaje.jpg" alt="Masaje 1">
            <div class="carousel-title">MASAJE FACIAL</div>
          </div>
          <div class="carousel-image">
            <img src="/msaje.jpg" alt="Masaje 2">
            <div class="carousel-title">MASAJE RELAJANTE</div>
          </div>
          <div class="carousel-image">
            <img src="/msaje.jpg" alt="Masaje 3">
            <div class="carousel-title">MASAJE CORPORAL</div>
          </div>
        </div>
        <button class="carousel-button prev" onclick="moveSlide(-1)">&#10094;</button>
        <button class="carousel-button next" onclick="moveSlide(1)">&#10095;</button>
      </div>
    </div>


  <!-- Script del carrusel -->
  <script>
    let currentIndex = 0;

    function moveSlide(direction) {
      const slide = document.getElementById('carouselSlide');
      const totalSlides = slide.children.length;

      currentIndex += direction;

      if (currentIndex < 0) {
        currentIndex = totalSlides - 1;
      } else if (currentIndex >= totalSlides) {
        currentIndex = 0;
      }

      slide.style.transform = `translateX(-${currentIndex * 100}%)`;
    }
  </script>
</body>
</html>
